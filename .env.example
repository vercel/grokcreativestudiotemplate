# ─── Required ───────────────────────────────────────────────────────
# Vercel AI Gateway API key (routes to xAI Grok models)
# Get one at https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=

# ─── Optional: Database (Neon PostgreSQL) ───────────────────────────
# Enables persistent storage for generations.
# Without this, the app uses 30 hardcoded seed items and returns
# new generations as base64 only (no permanent URLs).
# DATABASE_URL=postgresql://...

# ─── Optional: Vercel Blob Storage ──────────────────────────────────
# Enables permanent image/video URLs.
# Without this, generated images are returned as base64 only.
# BLOB_READ_WRITE_TOKEN=

# ─── Optional: Mux Video ───────────────────────────────────────────
# Enables HLS video streaming and auto-generated thumbnails.
# Without this, videos are served as direct MP4 files.
# MUX_TOKEN_ID=
# MUX_TOKEN_SECRET=

# ─── Optional: Mixedbread Vector Search ─────────────────────────────
# Enables visual/semantic search across generations.
# Without this, search uses text matching on prompts.
# MIXEDBREAD_API_KEY=
